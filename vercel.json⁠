// ============================================
// vercel.json (আপডেটেড)
// ============================================
{
  "version": 2,
  "builds": [
    {
      "src": "main.py",
      "use": "@vercel/python",
      "config": {
        "maxDuration": 60,
        "runtime": "python3.11"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "main.py"
    }
  ],
  "env": {
    "PYTHONPATH": ".",
    "DEBUG": "false"
  },
  "functions": {
    "main.py": {
      "memory": 1024,
      "maxDuration": 60
    }
  }
}
